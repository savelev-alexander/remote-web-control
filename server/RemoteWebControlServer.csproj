<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PublishAot>true</PublishAot>
    <InvariantGlobalization>true</InvariantGlobalization>
    <RootNamespace>RemoteWebControl</RootNamespace>
    <AssemblyName>remote-web-control-server</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <LinkerArg Include="-L$(MSBuildProjectDirectory)/native-libs" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="RemoteWebControlServer.Tests" />
  </ItemGroup>

  <!-- Тестовый проект лежит в подпапке; main project не должен компилировать его файлы. -->
  <ItemGroup>
    <Compile Remove="RemoteWebControlServer.Tests/**" />
    <Content Remove="RemoteWebControlServer.Tests/**" />
    <None Remove="RemoteWebControlServer.Tests/**" />
  </ItemGroup>
</Project>
